{
  "name": "musinsa-personal-shopper-plugin",
  "version": "0.4.0",
  "description": "Developer-facing ChatGPT/Codex plugin prototype for conversational MUSINSA shopping backed by crawled product ontology data.",
  "type": "module",
  "scripts": {
    "crawl:sample": "node scripts/crawl-musinsa-products.mjs --max 5 --out data/products.crawled.json --ontology docs/ontology/musinsa-product-ontology-sample.md",
    "analytics:export": "node scripts/export-personal-shopper-data-ontology.mjs",
    "index:build": "node scripts/build-search-index.mjs",
    "benchmark:search": "node scripts/benchmark-search-index.mjs",
    "cache:opencrab": "node scripts/build-opencrab-candidate-cache.mjs",
    "test:opencrab-adapter": "node scripts/test-opencrab-retrieval-adapter.mjs",
    "bridge:opencrab": "node scripts/opencrab-retrieval-bridge.mjs",
    "verify:opencrab-bridge": "node scripts/verify-real-opencrab-bridge.mjs",
    "verify:opencrab-live-bridge": "node scripts/verify-opencrab-live-command-bridge.mjs",
    "test:hybrid-opencrab": "node scripts/test-hybrid-opencrab-quality-gate.mjs",
    "verify:dashboard": "node scripts/verify-dashboard-live-api.mjs",
    "demo": "node scripts/demo.mjs",
    "enrich:products": "node scripts/enrich-product-ontology.mjs",
    "start": "node src/server.mjs",
    "test": "node --test tests/*.test.mjs"
  },
  "keywords": ["musinsa", "personal-shopper", "codex-plugin", "openapi", "ontology", "commerce-agent"],
  "license": "UNLICENSED",
  "engines": { "node": ">=22" }
}
